# ===========================================
# CatalogoX - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# -------------------------------------------
# Supabase (Required)
# https://supabase.com/dashboard/project/_/settings/api
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -------------------------------------------
# Cloudflare R2 - Image Storage (Required)
# https://dash.cloudflare.com → R2
# -------------------------------------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=catalogox-images
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# -------------------------------------------
# MercadoPago - Payments (Required for Pro subscriptions)
# https://www.mercadopago.com.mx/developers/panel/app
# -------------------------------------------
MP_PUBLIC_KEY=your_mercadopago_public_key
MP_ACCESS_TOKEN=your_mercadopago_access_token
MP_WEBHOOK_SECRET=your_mercadopago_webhook_secret

# -------------------------------------------
# Resend - Email (Required for weekly reports)
# https://resend.com/api-keys
# -------------------------------------------
RESEND_API_KEY=your_resend_api_key

# -------------------------------------------
# App Configuration
# -------------------------------------------
NEXT_PUBLIC_APP_URL=https://catalogox.vercel.app

# -------------------------------------------
# Cron Jobs Security
# Generate with: openssl rand -hex 32
# -------------------------------------------
CRON_SECRET=your_random_cron_secret
